# ─── משתני Build של הקליינט (Vite — נאפים לתוך ה-bundle בזמן build) ───
# דרושים ב-Railway כ-env vars — Vite קורא אותם בעת npm run build
VITE_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...   # מפתח anon בלבד (פומבי, לקריאות RLS-protected)

# ─── משתני ריצה של השרת (Express) ───
# כל אלה מוגדרים ב-Railway → Variables, לא ב-repo
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJ...         # anon key (לאחד עם הקליינט — אותו ערך)
SUPABASE_SERVICE_ROLE_KEY=eyJ... # service_role — לשרת בלבד! לעולם לא בקליינט
ANTHROPIC_API_KEY=sk-ant-...
TOGETHER_API_KEY=...
CLOUDINARY_CLOUD_NAME=...
CLOUDINARY_API_KEY=...
CLOUDINARY_API_SECRET=...
JWT_SECRET=...                   # מחרוזת אקראית ארוכה לחתימת JWT של תלמידים
PORT=3001                        # Railway מגדיר אוטומטית; אפשר להשמיט

# ─── מנהל-על ───
SUPERADMIN_EMAILS=admin@yourschool.com   # מופרד בפסיקים אם יש כמה
SUPERADMIN_EMAIL=admin@yourschool.com    # לסקריפט create-superadmin בלבד
SUPERADMIN_PASSWORD=...                  # לסקריפט create-superadmin בלבד

# ─── מיגרציות DB (npm run migrate) ───
# חיבור ישיר ל-Postgres של Supabase — נדרש רק להרצת DDL ידנית
DATABASE_URL=postgresql://postgres:PASSWORD@db.xxxxxxxxxxxxxxxxxxxx.supabase.co:5432/postgres
# או בנפרד:
SUPABASE_DB_HOST=db.xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_DB_PASSWORD=...
